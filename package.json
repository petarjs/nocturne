{
  "name": "nocturne",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @nocturne/web dev",
    "dev:server": "pnpm --filter @nocturne/server dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:golden": "pnpm --filter @nocturne/web test:golden",
    "test:golden:update": "pnpm --filter @nocturne/web test:golden:update",
    "tunnel": "cloudflared tunnel --url http://localhost:8787",
    "tunnel:web": "cloudflared tunnel --url http://localhost:3000"
  }
}
